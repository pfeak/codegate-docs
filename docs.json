{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "CodeGate",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "指南",
        "groups": [
          {
            "group": "入门",
            "pages": [
              "index",
              "quickstart",
              "llms"
            ]
          },
          {
            "group": "SDK",
            "pages": [
              "sdk/python",
              "sdk/javascript"
            ]
          },
          {
            "group": "AI 工具集成",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API 参考",
        "groups": [
          {
            "group": "API 概览",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "项目与激活码",
            "pages": [
              "api-reference/endpoint/get-project",
              "api-reference/endpoint/list-codes",
              "api-reference/endpoint/get-code",
              "api-reference/endpoint/get-code-by-code",
              "api-reference/endpoint/verify",
              "api-reference/endpoint/reactivate",
              "api-reference/endpoint/statistics"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/pfeak/codegate",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "支持",
        "href": "mailto:pfeak163@163.com"
      }
    ],
    "primary": {
